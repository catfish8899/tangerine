# ==============================================================================
# 3. Rust & Tauri 后端 (Rust & Tauri)
# ==============================================================================
# Rust 编译输出目录
/src-tauri/target/

# Tauri 自动生成的捆绑包和临时状态
/src-tauri/binaries/*
!/src-tauri/binaries/.gitkeep

# 排除 Python 打包到 binaries 中的临时 EXE，但保留配置好的 sidecar 可执行文件模板（如有）
# 注意：如果您习惯把打包好的 pyinstaller 成果直接手动丢进 binaries，可以取消下面这行的注释
# /src-tauri/binaries/*.exe

# ==============================================================================
# 4. Python 后端与虚拟环境 (Python & PyInstaller)
# ==============================================================================
# 虚拟环境 (Virtual Environments)
.venv/
venv/
ENV/
env/
python-env/

# Python 编译字节码与缓存
**/__pycache__/
**/*.py[cod]
**/*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# PyInstaller 打包产生的临时文件（Sidecar 打包必备）
/build/
*.manifest
*.spec

