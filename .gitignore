# ==============================================================================
# 1. 操作系统与编辑器特定文件 (OS & IDEs)
# ==============================================================================
# Windows & macOS 系统垃圾
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
.AppleDouble
.LSOverride
._*

# 个人编辑器配置（不提交，防止覆盖他人配置）
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
*.code-workspace
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==============================================================================
# 2. 前端依赖与构建产物 (React & Node.js)
# ==============================================================================
node_modules/
/dist/
/dist-ssr/
/out/

# 前端日志与临时文件
*.log
*debug.log*
yarn-error.log*
pnpm-lock.yaml~
.svelte-kit/
.nuxt/
.next/
.expo/

# ==============================================================================
# 3. Rust & Tauri 后端 (Rust & Tauri)
# ==============================================================================
# Rust 编译输出（非常庞大，绝对不能提交）
/src-tauri/target/

# Tauri 侧载二进制文件夹规则：
# 忽略 binaries 文件夹下的所有打包成果（防止把几十MB的.exe提到GitHub）
/src-tauri/binaries/*
# 唯独保留 .gitkeep 文件，从而让 Git 能够追踪并保留 binaries 空文件夹
!/src-tauri/binaries/.gitkeep

# ==============================================================================
# 4. Python 后端与虚拟环境 (Python & PyInstaller)
# ==============================================================================
# Python 虚拟环境
.venv/
venv/
ENV/
env/
python-env/

# Python 编译字节码与缓存
**/__pycache__/
**/*.py[cod]
**/*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# PyInstaller 打包产生的临时构建文件
/build/
*.manifest
*.spec

# ==============================================================================
# 5. AI、敏感配置与本地数据库 (AI & DBs)
# ==============================================================================
# 环境变量与密钥文件（含 API Key，绝对不能泄露）
.env
.env.local
.env.*.local
*.pem
*.key

# 本地 LLM 模型文件、权重（避免意外提交数 GB 的大文件）
*.gguf
*.bin
*.onnx
*.safetensors
/models/
/weights/

# 向量数据库与本地数据存储
*.db
*.sqlite
*.sqlite3
/data/
/vector_db/
.chroma/
