{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    "dialog:default",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "fs:allow-read",
    {
      "identifier": "fs:scope",
      "allow": [
        "$DESKTOP/**/*",
        "$PICTURE/**/*",
        "$DOWNLOAD/**/*",
        "$DOCUMENT/**/*",
        "$HOME/**/*"
      ],
      "deny": [
        "$APPLOCALDATA/EBWebView/**/*"
      ]
    }
  ]
}