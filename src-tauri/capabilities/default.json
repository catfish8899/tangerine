{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    "dialog:default",
    
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-copy-file",
    "fs:allow-remove",
    "fs:allow-read-dir",
    
    {
      "identifier": "fs:scope",
      "allow": [
        "$APPLOCALDATA/**",
        "$DESKTOP/**/*",
        "$PICTURE/**/*",
        "$DOWNLOAD/**/*",
        "$DOCUMENT/**/*",
        "$HOME/**/*"
      ],
      "deny": [
        "$APPLOCALDATA/EBWebView/**/*"
      ]
    }
  ]
}